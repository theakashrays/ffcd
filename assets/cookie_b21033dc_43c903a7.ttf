<script type="a969de21f5e5c61d19e0c479-text/javascript">
				$("#dropdown-more-open").on("click", function (e) {
					var document_width = $(document).outerWidth(),
						element_width = $("#dropdown-more").outerWidth(),
						from_left = $("#dropdown-more").parent().offset().left;
					if ((element_width + from_left) >= document_width) {
						$("#dropdown-more").css("right",  "0px");
						$("#dropdown-more").css("left",  "");
					}
					
					$("#dropdown-more").toggle();
					return false;
				});
				$("#dropdown-more").on("click", function (e) {
					e.stopPropagation();
				});
				$("body").on("click", function (e) {
					$("#dropdown-more").hide();
				});
			</script>


<script type="a969de21f5e5c61d19e0c479-text/javascript">
	//window.onscroll = function() {scrollFunction()};
     $(window).on('scroll', function () {
        var scrollTop = $(window).scrollTop();
        if (scrollTop > 35) {
            $('#headerlogo').stop().animate({height: "30px"},50);
        }
        else {
             $('#headerlogo').stop().animate({height: "60px"},50);   
        }
     });
     </script>
<script type="a969de21f5e5c61d19e0c479-text/javascript">
	window.onscroll = function() {scrollFunction()};
     $(window).on('scroll', function () {
        var scrollTop = $(window).scrollTop();
        if (scrollTop > 50) {
            $('#mobilenav').stop().animate({height: "0px"},50);
        }
        else {
             $('#mobilenav').stop().animate({height: "0px"},50); 
        }
     });
