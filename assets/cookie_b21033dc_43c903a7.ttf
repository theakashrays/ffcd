<script type="a969de21f5e5c61d19e0c479-text/javascript">

$(function(){
    $('.tab').click(function(){
        $('.tselected').removeClass('tselected');
        $(this).addClass('tselected');
        
        // Slide up all tabbed content
        $('.tabbed_content').slideUp(function() {
            $(this).css('display', 'none'); // Set display to none after slideUp animation
        });
        
        // Slide down the selected tabbed content
        var catshow = $(this).attr('rel').split(', '); // Splitting by comma and space
        $('#' + catshow).slideDown(function() {
            // Set display to grid for cat_177 when sliding down
            if (catshow.includes('#cat_177')) {
                $('#cat_177').css('display', 'grid');
            } else {
                // Set display to none for cat_177 when sliding down other tabs
                $('#cat_177').css('display', 'none');
            }
        });
    });
});

</script>

